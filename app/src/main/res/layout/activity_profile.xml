<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/koza_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/koza_green"
        app:title="Moj profil"
        app:titleTextColor="@color/koza_white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Avatar kartica -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/koza_green"
                app:cardElevation="6dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- Avatar krug -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        app:cardCornerRadius="36dp"
                        app:cardBackgroundColor="@color/koza_yellow"
                        android:layout_marginEnd="16dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_koza_logo"
                            android:padding="10dp"
                            android:scaleType="fitCenter" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Ime i email -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_ime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pero Perić"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/koza_white" />

                        <TextView
                            android:id="@+id/tv_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="pero@email.com"
                            android:textSize="13sp"
                            android:textColor="@color/koza_yellow"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tv_lokacija_profil"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 Pula, Istra"
                            android:textSize="12sp"
                            android:textColor="#CCFFFFFF"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Statistike (3 broja) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/koza_yellow_light"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_br_oglasa" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="3"
                            android:textSize="26sp" android:textStyle="bold" android:textColor="@color/koza_green" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Aktivnih" android:textSize="12sp" android:textColor="@color/text_gray" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tv_br_prodano" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="7"
                            android:textSize="26sp" android:textStyle="bold" android:textColor="@color/koza_green" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Prodano" android:textSize="12sp" android:textColor="@color/text_gray" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="★ 5.0" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/koza_yellow" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ocjena" android:textSize="12sp" android:textColor="@color/text_gray" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- LISTA OPCIJA PROFILA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Moji oglasi -->
                    <LinearLayout android:id="@+id/item_moji_oglasi"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:text="📋" android:textSize="20sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Moji oglasi"
                            android:textSize="15sp" android:textColor="@color/text_dark" />
                        <TextView android:text="›" android:textSize="22sp"
                            android:textColor="@color/text_gray"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginStart="56dp" />

                    <!-- Omiljeni artikli -->
                    <LinearLayout android:id="@+id/item_omiljeni"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:text="🐐" android:textSize="20sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Omiljeni artikli"
                            android:textSize="15sp" android:textColor="@color/text_dark" />
                        <TextView android:text="›" android:textSize="22sp"
                            android:textColor="@color/text_gray"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginStart="56dp" />

                    <!-- Moje narudžbe -->
                    <LinearLayout android:id="@+id/item_narudzbe"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:text="🛍️" android:textSize="20sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Moje narudžbe"
                            android:textSize="15sp" android:textColor="@color/text_dark" />
                        <TextView android:text="›" android:textSize="22sp"
                            android:textColor="@color/text_gray"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginStart="56dp" />

                    <!-- Moje prodaje -->
                    <LinearLayout android:id="@+id/item_prodaje"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:text="💰" android:textSize="20sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Moje prodaje"
                            android:textSize="15sp" android:textColor="@color/text_dark" />
                        <TextView android:text="›" android:textSize="22sp"
                            android:textColor="@color/text_gray"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Postavke kartica -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Postavke računa -->
                    <LinearLayout android:id="@+id/item_postavke"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:text="⚙️" android:textSize="20sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Postavke računa"
                            android:textSize="15sp" android:textColor="@color/text_dark" />
                        <TextView android:text="›" android:textSize="22sp"
                            android:textColor="@color/text_gray"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginStart="56dp" />

                    <!-- Pomoć -->
                    <LinearLayout android:id="@+id/item_pomoc"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="16dp"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:text="❓" android:textSize="20sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Pomoć i podrška"
                            android:textSize="15sp" android:textColor="@color/text_dark" />
                        <TextView android:text="›" android:textSize="22sp"
                            android:textColor="@color/text_gray"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Odjavi se -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_odjavi"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Odjavi se"
                android:textSize="15sp"
                android:textColor="@color/koza_white"
                android:backgroundTint="#D32F2F"
                android:layout_marginTop="4dp"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/koza_white"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/koza_green"
        app:itemTextColor="@color/koza_green" />

</LinearLayout>
